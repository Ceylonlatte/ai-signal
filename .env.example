# Postgres
DATABASE_URL=postgres://aisignal:aisignal@localhost:5432/aisignal
TEST_DATABASE_URL=postgres://aisignal:aisignal@localhost:5432/aisignal_test

# Ingest API (Mac collectors POST here)

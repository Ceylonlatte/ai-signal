# ===== Postgres 数据库 =====
# 应用运行库连接串（drizzle / worker / 仪表盘都用它）
DATABASE_URL=postgres://aisignal:aisignal@localhost:5432/aisignal
# 测试专用库连接串（vitest 集成测试用，绝不要指向生产库）
TEST_DATABASE_URL=postgres://aisignal:aisignal@localhost:5432/aisignal_test

# ===== 摄取 API =====
# 摄取接口的 bearer token：digest 采集脚本把 reddit/twitter 原始条目 POST 到 <host>/api/ingest
# 时需带上它。采集端的 AI_SIGNAL_INGEST_TOKEN 必须与此值完全一致。建议设成长随机串。
INGEST_TOKEN=change-me-long-random

# ===== 仪表盘登录（Google / NextAuth）=====
# 会话加密密钥：随机长串，用 `openssl rand -base64 32` 生成。生产必须设置（缺失会启动报错）。
AUTH_SECRET=
# Google OAuth 客户端 ID / 密钥：在 Google Cloud Console「APIs & Services → Credentials」
# 创建 OAuth client（应用类型选 Web application）。授权回调 URL 填：
#   生产： https://你的域名/api/auth/callback/google
#   本地： http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# 允许登录的 Google 邮箱白名单（逗号分隔）。为空 = 谁都不能登录（安全默认）。
# 例：AUTH_ALLOWED_EMAILS=you@gmail.com,teammate@gmail.com
AUTH_ALLOWED_EMAILS=
# 容器/反向代理部署需要：让 NextAuth 信任部署域名的 Host 头。生产建议 true。
AUTH_TRUST_HOST=true
# 自托管在反向代理/CDN（如 Cloudflare）后面时必须设为对外访问的完整域名，否则
# NextAuth 推断不到域名，点登录会跳到 http://localhost:3000。仅生产需要，本地
# 开发（localhost:3000）留空即可。例：AUTH_URL=https://your-domain.com
AUTH_URL=

# ===== OpenRouter（LLM / 嵌入，M2+）=====
# OpenRouter API key（sk-or-... 开头），用于打分、摘要、知识库笔记、嵌入等所有付费模型调用
OPENROUTER_API_KEY=
# 打分 / 摘要 / 知识库笔记所用的 LLM 模型
SCORING_MODEL=deepseek/deepseek-v4-flash
# 生成向量的嵌入模型（换模型需对整库重新嵌入，否则向量不可比）
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# 嵌入维度：qwen3-embedding-8b 原生 4096 维，这里用 MRL 切到 2048 以匹配 vector(2048) 表结构。
# 必须等于数据库 schema 里的维度，否则写入失败。
EMBEDDING_DIM=2048

# ===== 合成分（composite）各分量权重（M2）=====
# 平台热度分量权重
WEIGHT_HEAT=0.2
# 相关性分量权重
WEIGHT_RELEVANCE=0.2
# 新颖度分量权重
WEIGHT_NOVELTY=0.15
# LLM 价值分量权重
WEIGHT_LLM=0.45

# ===== 质量门 Q（时间无关、以 LLM 为主）=====
# 质量门槛：Q >= 此值的条目才进入信息流（低于则不展示）
Q_THRESHOLD=0.55
# twitter「following」的更低门槛——人工精选时间线更可信，更容易过门
Q_THRESHOLD_TWITTER_FOLLOWING=0.45
# Q 中「关键词/语义相关性」的权重
Q_WEIGHT_REL=0.15
# Q 中「来源可信度」的权重
Q_WEIGHT_TRUST=0.15
# 语义相关性余弦相似度下限：≤此值不贡献相关性，[下限, 1] 线性映射到 [0, 1]
RELEVANCE_SIM_THRESHOLD=0.45

# ===== 排序 R（实时、按 feed 计算）权重 =====
# R 中「质量分 Q」的权重
R_WEIGHT_Q=0.45
# R 中「平台热度」的权重
R_WEIGHT_HEAT=0.30
# R 中「新颖度」的权重
R_WEIGHT_NOVELTY=0.10
# R 中「点赞亲和度」的权重（与近期点赞内容相似则加分）
R_WEIGHT_AFFINITY=0.15
# 点踩软降权：从 R 中扣减，按与近期点踩内容的相似度缩放（软降，不硬隐藏）
R_WEIGHT_DISLIKE=0.15

# ===== 各平台热度的对数归一化除数 =====
# 除数越大，对该平台原始热度的压缩越强。HN 热度除数
HEAT_K_HN=2.5
# Reddit 热度除数
HEAT_K_REDDIT=2.5
# Twitter 热度除数
HEAT_K_TWITTER=3.5

# ===== 反馈画像（点赞/点踩）=====
# 与近期点踩内容的相似度 ≥ 此值则压制该条（进「已压制」板块）
SUPPRESS_THRESHOLD=0.92
# 被压制内容若与点赞内容相似度 ≥ 此值，则有机会被「救回」
RESCUE_SIM_THRESHOLD=0.85
# 救回的安全边际：点赞相似度需比点踩相似度高出此差值才救回
RESCUE_MARGIN=0.10
# 冷启动样本数：反馈样本少于此数时，亲和/降权效果按比例减弱
COLDSTART_N0=5
# 反馈画像的时间窗（天）：只用最近这些天的点赞/点踩参与排序
PROFILE_WINDOW_DAYS=90

# ===== 摘要阶段 =====
# 单条摘要的最大尝试次数，超过则死信跳过，不再反复重试
SUMMARY_MAX_ATTEMPTS=3

# ===== 知识库（收藏 → KB，项目 A）=====
# 抽取链：Firecrawl 主 → markdown.new（免费、无需 key）→ article-extractor → 已采文本
# Firecrawl 抽取器 API key（fc- 开头）。空则跳过 Firecrawl，抽取链从 markdown.new 起。免费档 1000 页/月。
FIRECRAWL_API_KEY=
# Cloudflare 账号 ID：即 S3 endpoint <id>.r2.cloudflarestorage.com 中间那串十六进制
R2_ACCOUNT_ID=
# R2 API token 的 Access Key ID（权限选 Object Read & Write）
R2_ACCESS_KEY_ID=
# 对应的 Secret Access Key（创建 token 时只显示一次，务必当场保存）
R2_SECRET_ACCESS_KEY=
# 存放知识库图片的 R2 桶名
R2_BUCKET=ai-signal-kb
# 图片对外访问的公共基地址（桶的 r2.dev 开发域或自定义域）。最终图片 URL = 此地址 + "/" + 对象 key
R2_PUBLIC_BASE_URL=
# worker 每轮最多处理多少条「已 ⭐ 待整理」的条目（限速，防止一次跑太多）
KB_FETCH_LIMIT=5
# 单条整理失败的最大重试次数，超过则状态置 failed
KB_MAX_ATTEMPTS=3
# 单张图片下载的大小上限（字节），超过则跳过该图（默认 5MB）
KB_MAX_IMAGE_BYTES=5000000
# 正文字符数低于此值则不生成结构化笔记，仅保留原文（状态置 skipped）
KB_MIN_BODY_CHARS=400
# 送入 LLM 生成笔记的正文最大字符数（超出截断，控制成本）
KB_NOTE_INPUT_CHARS=12000
